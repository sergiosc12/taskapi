# ============================================================
# .env.example — Plantilla de variables de entorno
# ============================================================
# INSTRUCCIONES:
# 1. Copia este archivo: cp .env.example .env
# 2. Rellena los valores reales en .env
# 3. NUNCA subas .env a Git (está en .gitignore)
# 4. En producción/CI, usa GitHub Secrets (ver README)
# ============================================================

# Configuración de la aplicación
NODE_ENV=development          # development | production | test
PORT=3000                     # Puerto en el que escucha la app
APP_VERSION=1.0.0             # Versión de la aplicación

# Base de datos (para cuando se conecte a una BD real)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=taskapi
# DB_USER=admin
# DB_PASSWORD=cambiar_esto_en_produccion   ← NUNCA hardcodear

# API Keys externas (se configuran como GitHub Secrets en CI)
# SENTRY_DSN=
# DATADOG_API_KEY=

# Docker Registry (para push de imágenes)
# DOCKER_REGISTRY=docker.io
# DOCKER_USERNAME=
# DOCKER_PASSWORD=   ← Usar GitHub Secret: ${{ secrets.DOCKER_PASSWORD }}
