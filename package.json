{
  "name": "taskapi",
  "version": "1.0.0",
  "description": "API REST de tareas — Demo DevOps & DevSecOps para exposición académica",
  "main": "src/server.js",
  "scripts": {
    "start":       "node src/server.js",
    "dev":         "nodemon src/server.js",
    "test":        "jest --coverage",
    "test:ci":     "jest --coverage --ci --forceExit",
    "lint":        "eslint src/ --ext .js",
    "lint:fix":    "eslint src/ --ext .js --fix"
  },
  "keywords": ["devops", "devsecops", "cicd", "nodejs", "api", "rest"],
  "author": "Tu Nombre",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": ["src/**/*.js"],
    "coverageThreshold": {
      "global": {
        "lines": 70
      }
    }
  }
}
